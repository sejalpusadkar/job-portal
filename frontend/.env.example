# Frontend environment variables (Vercel)
#
# On Vercel: Project -> Settings -> Environment Variables.
# Locally: copy to `frontend/.env` (DO NOT commit real secrets).

# Backend origin (Railway)
# Example: https://job-portal-production-xxxx.up.railway.app
REACT_APP_API_BASE_URL=https://job-portal-production-xxxx.up.railway.app
