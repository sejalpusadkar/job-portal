# Copy to .env and adjust for your environment.

# Docker Compose (local)
# NOTE: Do not commit real secrets. Fill these in your local `.env`.

MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=job_portal_db

PORT=8080
DB_URL=jdbc:mysql://mysql:3306/job_portal_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=change-me

JWT_SECRET=CHANGE_ME_32_CHARS_MINIMUM________________________
FRONTEND_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# SMTP (optional but required for password reset emails)
MAIL_REQUIRED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
