# Backend environment variables (Render)
#
# Copy this file to `.env` locally (DO NOT commit real secrets).
# On Render, set these in "Environment" settings instead.

# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Render provides PORT automatically; keep this for local/prod parity.
PORT=8080

# Database (Railway MySQL)
# Example: jdbc:mysql://containers-us-west-xx.railway.app:6543/railway?useSSL=true&serverTimezone=UTC
DB_URL=jdbc:mysql://<railway-host>:<port>/<db>?useSSL=true&serverTimezone=UTC
DB_USERNAME=<db-username>
DB_PASSWORD=<db-password>

# Security (required)
JWT_SECRET=CHANGE_ME_32_CHARS_MINIMUM________________________

# CORS / Password reset link base
FRONTEND_ORIGIN=https://<your-vercel-domain>.vercel.app
CORS_ALLOWED_ORIGINS=https://<your-vercel-domain>.vercel.app

# Admin registration safety gate (optional)
ADMIN_REGISTRATION_CODE=

# Email (optional but required for "Forgot Password" emails)
MAIL_REQUIRED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=<your-email@gmail.com>
SMTP_PASSWORD=<your-app-password>
SMTP_FROM=<your-email@gmail.com>
MAIL_DEBUG=false

